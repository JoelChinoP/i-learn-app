# Copy this file to `.env` and replace placeholders locally.
# Never expose management credentials or AI keys through a `VITE_*` variable.

# Browser-safe values: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Local CLI access: Dashboard project reference, personal access token, and DB password
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_ACCESS_TOKEN=sbp_REPLACE_ME
SUPABASE_DB_PASSWORD=REPLACE_ME

# Edge Function secrets. Choose OpenAI or Anthropic for generation.
# RAG embeddings still require a compatible embedding provider/model.
AI_GENERATION_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Values aligned with the implementation document and migration.sql
EMBEDDING_DIMENSIONS=1536
MASTERY_THRESHOLD=0.75
ANSWER_MAX_LENGTH=4000
ORCHESTRATION_TIMEOUT_MS=28000
